<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash: show the app logo on white so it matches the
         in-app branded splash for a seamless handoff. -->
    <style name="Theme.AndroidSignals" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="android:windowSplashScreenAnimationDuration">600</item>
    </style>
</resources>
